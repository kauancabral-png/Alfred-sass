# Variaveis de Servidor Port e CORS
PORT=8080
NODE_ENV=development

# Postgres Data Base URL Local / Railway
DATABASE_URL="postgresql://user:password@localhost:5432/fincontrol?schema=public"

# Configuracoes de Token
JWT_SECRET="FINCONTROL_CHAVE_SUPER_SECRETA_DO_SISTEMA_AQUI"

# Stripe Payments Config (Pagamentos e Assinaturas)
STRIPE_SECRET_KEY="sua_chave_secreta_da_stripe_aqui"
STRIPE_WEBHOOK_SECRET="whsec_..."

# Twilio (Integração WhatsApp Bot)
TWILIO_ACCOUNT_SID="AC_SuaConta_..."
TWILIO_AUTH_TOKEN="seu_token_..."
TWILIO_WHATSAPP_NUMBER="whatsapp:+14155238886"

# Frontend Integration
CORS_ORIGIN="http://localhost:5173"
